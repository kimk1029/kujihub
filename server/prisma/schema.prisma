generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Kuji {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String?      @map("image_url")
  price       Int
  boardSize   Int          @default(80) @map("board_size")
  status      String       @default("active") // active | sold_out | draft
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  prizes KujiPrize[]
  slots  KujiSlot[]
  purchases KujiPurchase[]

  @@map("kujis")
}

model KujiPlayer {
  id        String         @id
  nickname  String         @default("게스트")
  points    Int            @default(100000)
  role      String         @default("user") // "user" or "admin"
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  purchases KujiPurchase[]

  @@map("kuji_players")
}

model KujiPurchase {
  id           String     @id
  kujiId       Int        @map("kuji_id")
  playerId     String     @map("player_id")
  quantity     Int
  totalPrice   Int        @map("total_price")
  status       String     @default("pending")
  selectedSlots Json?     @map("selected_slots")
  resultJson   Json?      @map("result_json")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  kuji   Kuji       @relation(fields: [kujiId], references: [id], onDelete: Cascade)
  player KujiPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@index([kujiId, createdAt])
  @@map("kuji_purchases")
}

model CommunityPost {
  id        Int                 @id @default(autoincrement())
  category  String              @default("자유")
  isNotice  Boolean             @default(false) @map("is_notice")
  title     String
  content   String              @default("")
  author    String              @default("익명")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  feedItems CommunityFeedItem[]
  comments  CommunityComment[]

  @@map("community_posts")
}

model CommunityComment {
  id        Int           @id @default(autoincrement())
  postId    Int           @map("post_id")
  author    String        @default("익명")
  content   String
  createdAt DateTime      @default(now()) @map("created_at")
  
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  @@index([postId, createdAt])
  @@map("community_comments")
}

model CommunityFeedItem {
  id        Int            @id @default(autoincrement())
  type      String
  source    String         @default("community")
  title     String
  body      String
  author    String?
  imageUrl  String?        @map("image_url")
  link      String?
  postId    Int?           @map("post_id")
  createdAt DateTime       @default(now()) @map("created_at")
  post      CommunityPost? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("community_feed_items")
}

model KujiPrize {
  id           Int    @id @default(autoincrement())
  kujiId       Int    @map("kuji_id")
  grade        String
  name         String
  color        String @default("#718096")
  chance       Float  // 누적 확률 0.0 ~ 1.0
  displayOrder Int    @default(0) @map("display_order")

  kuji Kuji @relation(fields: [kujiId], references: [id], onDelete: Cascade)

  @@map("kuji_prizes")
}

model KujiSlot {
  kujiId       Int       @map("kuji_id")
  slotNumber   Int       @map("slot_number")
  status       String    // locked | drawn
  grade        String?
  gradeName    String?   @map("grade_name")
  gradeColor   String?   @map("grade_color")
  lockedAt     DateTime? @map("locked_at")
  lockedUserId String?   @map("locked_user_id")
  completedAt  DateTime? @map("completed_at")

  kuji Kuji @relation(fields: [kujiId], references: [id], onDelete: Cascade)

  @@id([kujiId, slotNumber])
  @@map("kuji_slots")
}
